# Firebase config
# For local development with emulators, these values can be anything non-empty.
# The emulator doesn't validate API keys.
# Prerequisite: Java 11+ required for Firebase emulators.
VITE_FIREBASE_API_KEY=fake-api-key-for-emulator
VITE_FIREBASE_AUTH_DOMAIN=skill-plepic-com.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=skill-plepic-com
VITE_FIREBASE_STORAGE_BUCKET=skill-plepic-com.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:fake
